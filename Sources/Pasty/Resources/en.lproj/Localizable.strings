"onboarding.04.subtitle" = "Required to auto-paste. Pasty never sends history outside this Mac.";
"onboarding.05.title" = "Organize with folders";
"onboarding.05.subtitle" = "Click + in header to create folders. Tab/⇧Tab to switch.";
"onboarding.06.title" = "Three ways to file clips";
