"onboarding.09b.subtitle" = "Pauses clipboard history for 60 seconds. Use it for passwords and personal info.";
"onboarding.10b.title" = "Quick Paste — ⌃⌥1–5";
"onboarding.10b.subtitle" = "Assigns numbers to your 5 most recent clips. Paste any with the modifier and a digit, no panel needed.";
"onboarding.11.title" = "All set.";
